{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "model": "openai/gpt-5.5",
  "small_model": "opencode-go/deepseek-v4-flash",
  "enabled_providers": ["openai", "opencode-go"],
  "share": "disabled",
  "permission": {
    "*": "ask",
    "read": "allow",
    "grep": "allow",
    "glob": "allow",
    "bash": {
      "*": "ask",
      "pwd": "allow",
      "ls*": "allow",
      "git status*": "allow",
      "git diff*": "allow",
      "pytest*": "allow",
      "python wave_energy.py*": "allow",
      "rm *": "deny",
      "git push*": "deny",
      "git commit*": "deny"
    },
    "edit": "ask",
    "webfetch": "ask",
    "websearch": "ask",
    "task": {
      "*": "deny",
      "paper-scout": "allow",
      "reviewer": "ask"
    },
    "skill": {
      "*": "ask",
      "wave-*": "allow"
    }
  },
  "agent": {
    "plan": {
      "description": "Planifie la traduction papier vers code. Lecture seule, hypothèses, fonctions, tests.",
      "mode": "primary",
      "model": "openai/gpt-5.5",
      "prompt": "{file:./.opencode/prompts/plan.md}",
      "temperature": 0.1,
      "steps": 8,
      "reasoningEffort": "high",
      "textVerbosity": "low",
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "ask",
          "pwd": "allow",
          "ls*": "allow",
          "grep*": "allow",
          "git status*": "allow"
        },
        "task": {
          "*": "deny",
          "paper-scout": "allow",
          "reviewer": "ask"
        }
      }
    },
    "build": {
      "description": "Implémente le plan, écrit les tests, lance pytest et produit le rapport.",
      "mode": "primary",
      "model": "opencode-go/deepseek-v4-flash",
      "prompt": "{file:./.opencode/prompts/build.md}",
      "temperature": 0.1,
      "steps": 18,
      "permission": {
        "edit": "ask",
        "bash": {
          "*": "ask",
          "pwd": "allow",
          "ls*": "allow",
          "git status*": "allow",
          "git diff*": "allow",
          "pytest*": "allow",
          "python wave_energy.py*": "allow",
          "rm *": "deny",
          "git push*": "deny",
          "git commit*": "deny"
        },
        "task": {
          "*": "deny",
          "reviewer": "ask"
        }
      }
    },
    "paper-scout": {
      "description": "Extrait formule, variables, unités, hypothèses et limites depuis l'extrait scientifique. Lecture seule.",
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-flash",
      "prompt": "{file:./.opencode/prompts/paper-scout.md}",
      "temperature": 0.1,
      "steps": 6,
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "webfetch": "ask",
        "websearch": "ask"
      }
    },
    "reviewer": {
      "description": "Relit diff, formule, unités, tests et rapport. Revue scientifique/code en lecture seule.",
      "mode": "subagent",
      "model": "openai/gpt-5.5",
      "prompt": "{file:./.opencode/prompts/reviewer.md}",
      "temperature": 0.1,
      "steps": 8,
      "reasoningEffort": "medium",
      "textVerbosity": "low",
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "ask",
          "git diff*": "allow",
          "pytest*": "allow"
        },
        "webfetch": "ask",
        "websearch": "ask"
      }
    }
  }
}
